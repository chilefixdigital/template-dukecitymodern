{% if testimonials and testimonials.items and testimonials.items.length > 0 %}
<section class="reviews-section section" id="reviews">
  <div class="container">
    <h2 class="section-heading">What Our Customers Say</h2>
    {% for t in testimonials.items %}
      <div class="review-card">
        <div class="review-stars">{% for i in range(0, t.rating) %}&#9733;{% endfor %}</div>
        <details class="review-text-wrap">
          <summary class="review-text">{{ t.text }}</summary>
          <p>{{ t.text }}</p>
        </details>
        <div class="review-footer">
          <span class="review-avatar">{{ t.initials }}</span>
          <span class="review-author">{{ t.author }}</span>
          <span class="review-badge">{{ t.source }} Review</span>
        </div>
      </div>
    {% endfor %}
    {% if client.socials.google %}
      <a href="{{ client.socials.google }}" class="reviews-link" target="_blank" rel="noopener">See all reviews on Google &rarr;</a>
    {% endif %}
  </div>
</section>
{% endif %}
