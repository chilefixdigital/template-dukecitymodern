<!-- ============================================ -->
<!--                  Full Menu                    -->
<!-- ============================================ -->
{% if menu and menu.categories %}
{% set totalItems = 0 %}
{% for cat in menu.categories %}
  {% set totalItems = totalItems + cat.items.length %}
{% endfor %}
{% set collapsible = totalItems > 10 %}

<section class="menu-section" id="menu">
    <div class="section-header">
        <div class="section-label">Our Kitchen</div>
        <h2 class="section-title">Our Menu</h2>
    </div>
    <div class="menu-categories">
        {% for cat in menu.categories %}
        <div class="menu-category{% if collapsible %} collapsible{% endif %}{% if loop.index <= 2 %} open{% endif %}">
            <h3 class="menu-category-title"{% if collapsible %} role="button" aria-expanded="{% if loop.index <= 2 %}true{% else %}false{% endif %}" tabindex="0"{% endif %}>
                {{ cat.name }}
                {% if collapsible %}<span class="menu-toggle-icon" aria-hidden="true"></span>{% endif %}
            </h3>
            <div class="menu-items{% if collapsible and loop.index > 2 %} collapsed{% endif %}">
                {% for item in cat.items %}
                <div class="menu-item">
                    <div class="menu-item-info">
                        <span class="menu-item-name">{{ item.name }}</span>
                        {% if item.description %}
                        <span class="menu-item-desc">{{ item.description }}</span>
                        {% endif %}
                    </div>
                    {% if item.price and item.price != "$" and item.price != "" %}
                    <span class="menu-item-price">{{ item.price }}</span>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% endif %}
